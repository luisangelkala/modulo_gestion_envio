<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="ir.module.category" id="module_category_shipping">
            <field name="name">Gestión de Envíos</field>
            <field name="description">Control de acceso para Logística</field>
            <field name="sequence">10</field>
        </record>

        <!-- Rol Tráfico: Solo líneas -->
        <record id="group_shipping_traffic" model="res.groups">
            <field name="name">Tráfico</field>
            <field name="category_id" ref="module_category_shipping"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Rol Administrador: Control total -->
        <record id="group_shipping_manager" model="res.groups">
            <field name="name">Administrador</field>
            <field name="category_id" ref="module_category_shipping"/>
            <field name="implied_ids" eval="[(4, ref('group_shipping_traffic'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>