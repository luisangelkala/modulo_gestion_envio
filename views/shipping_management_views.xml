<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form View -->
    <record id="view_shipping_management_form" model="ir.ui.view">
        <field name="name">shipping.management.form</field>
        <field name="model">shipping.management</field>
        <field name="arch" type="xml">
            <form string="Gestión de Envío">
                <header>
                    <!-- Botón confirmar solo para admins (controlado por groups en python o botón) -->
                    <button name="action_confirm" string="Confirmar" type="object" class="oe_highlight" 
                            invisible="state != 'draft'" groups="modulo_gestion_envio.group_shipping_manager"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed"/>
                </header>
                <sheet>
                    <!-- Dashboard / Smart Stats -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_dummy" type="object" class="oe_stat_button" icon="fa-cubes">
                            <field name="total_packages" widget="statinfo" string="Bultos"/>
                        </button>
                        <button name="action_dummy" type="object" class="oe_stat_button" icon="fa-balance-scale">
                            <field name="total_weight" widget="statinfo" string="Kg Total"/>
                        </button>
                        <button name="action_dummy" type="object" class="oe_stat_button" icon="fa-archive">
                            <field name="total_volume" widget="statinfo" string="m³ Total"/>
                        </button>
                        <button name="action_dummy" type="object" class="oe_stat_button" icon="fa-users">
                            <field name="unique_client_count" widget="statinfo" string="Clientes"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="transport_type" readonly="state == 'confirmed'"/>
                            <field name="container_type_id" 
                                   invisible="transport_type == 'air'" 
                                   required="transport_type == 'sea'"
                                   readonly="state == 'confirmed'"/>
                        </group>
                        <group>
                            <field name="date_shipping" readonly="state == 'confirmed'"/>
                            <field name="carrier" readonly="state == 'confirmed'"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Líneas de Carga" name="lines">
                            <field name="line_ids" readonly="state == 'confirmed'">
                                <tree editable="bottom">
                                    <field name="partner_id"/>
                                    <field name="package_code"/>
                                    <field name="length"/>
                                    <field name="width"/>
                                    <field name="height"/>
                                    <field name="volume" sum="Total Vol"/>
                                    <field name="weight" sum="Total Peso"/>
                                    <!-- Botón Duplicar -->
                                    <button name="action_duplicate_line" type="object" icon="fa-copy" title="Duplicar Línea"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Tree View -->
    <record id="view_shipping_management_tree" model="ir.ui.view">
        <field name="name">shipping.management.tree</field>
        <field name="model">shipping.management</field>
        <field name="arch" type="xml">
            <tree decoration-info="state == 'draft'" decoration-success="state == 'confirmed'">
                <field name="name"/>
                <field name="date_shipping"/>
                <field name="transport_type"/>
                <field name="carrier"/>
                <field name="total_packages"/>
                <field name="total_weight"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'confirmed'"/>
            </tree>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_shipping_management_search" model="ir.ui.view">
        <field name="name">shipping.management.search</field>
        <field name="model">shipping.management</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="carrier"/>
                <filter string="Aéreo" name="air" domain="[('transport_type', '=', 'air')]"/>
                <filter string="Marítimo" name="sea" domain="[('transport_type', '=', 'sea')]"/>
                <separator/>
                <filter string="Borrador" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Confirmado" name="confirmed" domain="[('state', '=', 'confirmed')]"/>
            </search>
        </field>
    </record>

    <action id="action_shipping_management" model="ir.actions.act_window">
        <field name="name">Gestión de Envíos</field>
        <field name="res_model">shipping.management</field>
        <field name="view_mode">tree,form</field>
    </action>

    <menuitem id="menu_shipping_root" name="Logística" web_icon="modulo_gestion_envio,static/description/icon.png"/>
    <menuitem id="menu_shipping_management" parent="menu_shipping_root" action="action_shipping_management" sequence="10"/>
</odoo>