<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_shipping_management_form" model="ir.ui.view">
        <field name="name">shipping.management.form</field>
        <field name="model">shipping.management</field>
        <field name="arch" type="xml">
            <form string="Gestión de Envío">
                <header>
                    <button name="action_confirm" string="Confirmar" type="object" class="oe_highlight" 
                            invisible="state != 'draft'" groups="modulo_gestion_envio.group_shipping_manager"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_dummy" type="object" class="oe_stat_button" icon="fa-cubes">
                            <field name="total_packages" widget="statinfo" string="Bultos"/>
                        </button>
                        <button name="action_dummy" type="object" class="oe_stat_button" icon="fa-balance-scale">
                            <field name="total_weight" widget="statinfo" string="Kg Total"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="transport_type" widget="radio" readonly="state == 'confirmed'"/>
                            <field name="container_type_id" invisible="transport_type != 'sea'" 
                                   required="transport_type == 'sea'" readonly="state == 'confirmed'"/>
                        </group>
                        <group>
                            <field name="date_shipping" readonly="state == 'confirmed'"/>
                            <field name="carrier" readonly="state == 'confirmed'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Líneas de Carga" name="lines">
                            <field name="line_ids" readonly="state == 'confirmed'">
                                <tree editable="bottom">
                                    <field name="partner_id"/>
                                    <field name="package_code" readonly="1"/>
                                    <field name="length"/>
                                    <field name="width"/>
                                    <field name="height"/>
                                    <field name="volume" sum="Total Vol"/>
                                    <field name="weight" sum="Total Peso"/>
                                    <button name="action_duplicate_line" type="object" icon="fa-copy" title="Duplicar Línea"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    </odoo>