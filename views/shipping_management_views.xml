<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vistas para el Catálogo de Referencias (Configuración) -->
    <record id="view_shipping_reference_catalog_tree" model="ir.ui.view">
        <field name="name">shipping.reference.catalog.tree</field>
        <field name="model">shipping.reference.catalog</field>
        <field name="arch" type="xml">
            <tree string="Catálogo de Referencias" editable="bottom">
                <field name="name"/>
                <field name="transport_type"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <!-- Acción: Guías Aéreas -->
    <record id="action_shipping_reference_catalog_air" model="ir.actions.act_window">
        <field name="name">Guías Aéreas</field>
        <field name="res_model">shipping.reference.catalog</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('transport_type', '=', 'air')]</field>
        <field name="context">{'default_transport_type': 'air'}</field>
    </record>

    <!-- Acción: Manifiestos Marítimos -->
    <record id="action_shipping_reference_catalog_sea" model="ir.actions.act_window">
        <field name="name">Manifiestos Marítimos</field>
        <field name="res_model">shipping.reference.catalog</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('transport_type', '=', 'sea')]</field>
        <field name="context">{'default_transport_type': 'sea'}</field>
    </record>

    <record id="view_shipping_management_form" model="ir.ui.view">
        <field name="name">shipping.management.form</field>
        <field name="model">shipping.management</field>
        <field name="arch" type="xml">
            <form string="Gestión de Envío">
                <header>
                    <button name="action_confirm" string="Confirmar" type="object" class="oe_highlight" 
                            invisible="state != 'draft'" groups="modulo_gestion_envio.group_shipping_manager"
                            confirm="¿Está seguro que desea confirmar este envío? Esta acción es irreversible."/>
                    <button name="%(modulo_gestion_envio.action_report_shipping_labels)d" string="Imprimir Etiquetas" type="action" 
                            class="btn-secondary"/>
                    <button name="action_print_bl" string="Imprimir HBL" type="object" class="oe_highlight" groups="modulo_gestion_envio.group_shipping_manager"/>
                    <button name="action_export_manifest_excel" type="object" string="Exportar Manifiesto (Excel)" class="oe_highlight" icon="fa-file-excel-o"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_dummy" type="object" class="oe_stat_button" icon="fa-users">
                            <field name="unique_client_count" widget="statinfo" string="Clientes"/>
                        </button>
                        <button name="action_dummy" type="object" class="oe_stat_button" icon="fa-cubes">
                            <field name="total_packages" widget="statinfo" string="Bultos"/>
                        </button>
                        <button name="action_dummy" type="object" class="oe_stat_button" icon="fa-balance-scale">
                            <field name="total_weight" widget="statinfo" string="Kg Total"/>
                        </button>
                        <button name="action_dummy" type="object" class="oe_stat_button" icon="fa-cube">
                            <field name="total_volume" widget="statinfo" string="m³ Total"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="reference_id" class="oe_edit_only" string="Referencia"/>
                        <h1>
                            <field name="reference_id" options="{'no_create': True, 'no_open': True}" 
                                   placeholder="Seleccione Guía o Manifiesto..." 
                                   domain="[('transport_type', '=', transport_type)]"
                                   readonly="state == 'confirmed'" required="1"/>
                        </h1>
                        <field name="name" invisible="1"/>
                    </div>
                    <group>
                        <group>
                            <field name="agencia_origen" readonly="state == 'confirmed'" options="{'no_create': False}"/>
                            <field name="pais_id" readonly="state == 'confirmed'"/>
                            <field name="transport_type" widget="radio" readonly="state == 'confirmed'"/>
                            <field name="container_type_id" invisible="transport_type != 'sea'" 
                                   required="transport_type == 'sea'" readonly="state == 'confirmed'"/>
                        </group>
                        <group>
                            <field name="consignatario_id" readonly="state == 'confirmed'"/>
                            <field name="awb" readonly="state == 'confirmed'"/>
                            <field name="date_shipping" readonly="state == 'confirmed'"/>
                            <field name="carrier" readonly="state == 'confirmed'" options="{'no_create': False}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Líneas de Carga" name="lines">
                            <field name="line_search" placeholder="🔍 Escriba para filtrar por Código, Cliente, Remitente o Destinatario..." class="mb-2"/>
                            <field name="line_ids_display" widget="one2many" context="{'default_shipping_id': id}" readonly="state == 'confirmed'">
                                <!-- Vista de Lista (resumen) -->
                                <tree>
                                    <control>
                                        <create name="add_line_control" string="Agregar nuevo envío"/>
                                    </control>
                                    <field name="print_selected" widget="boolean_toggle" string="Imp."/>
                                    <field name="package_code"/>
                                    <field name="customer_id"/>
                                    <field name="sender_id"/>
                                    <field name="receiver_id"/>
                                    <field name="description"/>
                                    <field name="packages_qty" sum="Total Bultos"/>
                                    <field name="weight" sum="Total Peso"/>
                                    <field name="volume" sum="Total Volumen"/>
                                    <button name="action_duplicate_line" type="object" icon="fa-copy" title="Duplicar Línea"/>
                                </tree>
                                <!-- Vista de Formulario (popup modal) -->
                                <form>
                                    <sheet>
                                        <group>
                                            <field name="print_selected" widget="boolean_toggle"/>
                                            <group string="Contactos">
                                                <field name="customer_id" options="{'no_open': True}"/>
                                                <field name="sender_id" required="1"/>
                                                <field name="receiver_id" required="1"/>
                                                <field name="shipping_type"/>
                                            </group>
                                            <group string="Detalle de Carga">
                                                <field name="package_code"/>
                                                <field name="description"/>
                                                <field name="packages_qty"/>
                                            </group>
                                        </group>
                                        <group string="Dimensiones y Peso">
                                            <group>
                                                <field name="length"/>
                                                <field name="width"/>
                                                <field name="height"/>
                                            </group>
                                            <group><field name="weight"/><field name="volume" readonly="1"/></group>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_shipping_management_tree" model="ir.ui.view">
        <field name="name">shipping.management.tree</field>
        <field name="model">shipping.management</field>
        <field name="arch" type="xml">
            <tree string="Envíos" decoration-muted="state == 'confirmed'" decoration-info="state == 'draft'">
                <field name="name"/>
                <field name="date_shipping"/>
                <field name="transport_type" widget="badge" decoration-success="transport_type == 'sea'" decoration-warning="transport_type == 'air'"/>
                <field name="carrier"/>
                <field name="total_packages" sum="Total Bultos"/>
                <field name="total_weight" sum="Total Peso"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'confirmed'"/>
            </tree>
        </field>
    </record>

    <record id="action_shipping_management" model="ir.actions.act_window">
        <field name="name">Gestión de Envíos</field>
        <field name="res_model">shipping.management</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_shipping_management_act" 
              name="Operaciones" 
              parent="menu_shipping_root" 
              action="action_shipping_management" 
              sequence="10"/>

    <!-- Menús de Configuración -->
    
    <menuitem id="menu_shipping_config_root"
              name="Configuración"
              parent="menu_shipping_root"
              sequence="100"/>

    <menuitem id="menu_shipping_config_air"
              name="Guías Aéreas"
              parent="menu_shipping_config_root"
              action="action_shipping_reference_catalog_air"/>

    <menuitem id="menu_shipping_config_sea"
              name="Manifiestos"
              parent="menu_shipping_config_root"
              action="action_shipping_reference_catalog_sea"/>

</odoo>