<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_shipping_container_type_tree" model="ir.ui.view">
        <field name="name">shipping.container.type.tree</field>
        <field name="model">shipping.container.type</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="name"/>
                <field name="capacity_m3"/>
                <field name="capacity_kg"/>
                <field name="length"/>
                <field name="width"/>
                <field name="height"/>
            </tree>
        </field>
    </record>

    <record id="action_shipping_container_type" model="ir.actions.act_window">
        <field name="name">Tipos de Contenedor</field>
        <field name="res_model">shipping.container.type</field>
        <field name="view_mode">tree</field>
    </record>

    <menuitem id="menu_shipping_container_type" parent="menu_shipping_config" action="action_shipping_container_type" sequence="10"/>
</odoo>
</odoo>