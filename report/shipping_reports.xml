<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Action: Etiquetas -->
        <record id="action_report_shipping_labels" model="ir.actions.report">
            <field name="name">Etiquetas de Bulto (QR)</field>
            <field name="model">shipping.management</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">modulo_gestion_envio.report_shipping_labels</field>
            <field name="report_file">modulo_gestion_envio.report_shipping_labels</field>
            <field name="print_report_name">'Etiquetas - %s' % object.name</field>
        </record>

        <!-- Action: HBL -->
        <record id="action_report_shipping_hbl" model="ir.actions.report">
            <field name="name">HBL (3 Copias)</field>
            <field name="model">shipping.management</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">modulo_gestion_envio.report_shipping_hbl</field>
            <field name="report_file">modulo_gestion_envio.report_shipping_hbl</field>
            <field name="print_report_name">'HBL - %s' % object.name</field>
        </record>

        <!-- Action: Manifiesto de Carga (BL) - Sin Binding para evitar Error #003 -->
        <record id="action_report_shipping_bl" model="ir.actions.report">
            <field name="name">Manifiesto de Carga (BL)</field>
            <field name="model">shipping.management</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">modulo_gestion_envio.template_report_shipping_bl</field>
            <field name="report_file">modulo_gestion_envio.template_report_shipping_bl</field>
            <field name="print_report_name">'Manifiesto - %s' % object.name</field>
        </record>

        <!-- Template: Etiquetas -->
        <template id="report_shipping_labels">
            <t t-call="web.basic_layout">
                <div class="page">
                    <t t-foreach="docs" t-as="o">
                        <t t-foreach="o.line_ids" t-as="line">
                            <div style="page-break-after: always; border: 2px solid black; padding: 15px; text-align: center; margin: 10px;">
                                <h3>REF: <span t-field="o.name"/></h3>
                                <div style="margin: 20px 0;">
                                    <!-- Generación de QR usando el endpoint nativo de Odoo -->
                                    <img t-att-src="'/report/barcode/?barcode_type=QR&amp;value=%s&amp;width=200&amp;height=200' % o.name" style="width:200px;height:200px"/>
                                </div>
                                <strong>Bulto ID:</strong> <span t-field="line.package_code"/><br/>
                                <strong>Cliente:</strong> <span t-field="line.receiver_id.name"/><br/>
                                <strong>Destino:</strong> <span t-field="line.receiver_id.city"/>, <span t-field="line.receiver_id.country_id.code"/>
                            </div>
                        </t>
                    </t>
                </div>
            </t>
        </template>

        <!-- Template: HBL -->
        <template id="report_shipping_hbl">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-foreach="o.line_ids" t-as="line">
                        <!-- Loop para 3 copias -->
                        <t t-foreach="[1, 2, 3]" t-as="copy_idx">
                            <!-- Contenedor optimizado: 48% alto para caber 2 por A4 -->
                            <div class="article" t-att-style="'position: relative; height: 48vh; border: 1px solid #333; margin-bottom: 1vh; padding: 10px; box-sizing: border-box; page-break-inside: avoid; ' + ('page-break-after: always;' if copy_idx % 2 == 0 and copy_idx != 3 else '')">
                                
                                <div class="row">
                                    <div class="col-6">
                                        <h4>HOUSE BILL OF LADING</h4>
                                        <small>Copy <t t-esc="copy_idx"/>/3</small>
                                    </div>
                                    <div class="col-6 text-end">
                                        <h3><span t-field="o.name"/></h3>
                                    </div>
                                </div>
                                <hr/>
                                <div class="row mt-2">
                                    <div class="col-6">
                                        <strong>Shipper:</strong><br/>
                                        [Nombre de tu Empresa]<br/>
                                        Logistics Dept.
                                    </div>
                                    <div class="col-6">
                                        <strong>Consignee:</strong><br/>
                                        <span t-field="line.receiver_id.name"/><br/>
                                        <span t-field="line.receiver_id.street"/><br/>
                                        <span t-field="line.receiver_id.city"/>
                                    </div>
                                </div>
                                
                                <table class="table table-sm table-bordered mt-4">
                                    <thead>
                                        <tr><th>Package Code</th><th>Dims (L*W*H)</th><th>Vol (m³)</th><th>Weight (Kg)</th></tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td><span t-field="line.package_code"/></td>
                                            <td><span t-field="line.length"/> x <span t-field="line.width"/> x <span t-field="line.height"/></td>
                                            <td><span t-field="line.volume"/></td>
                                            <td><span t-field="line.weight"/></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                            <!-- Si es la 2da copia, forzamos salto de página para que la 3ra quede en hoja nueva (o flujo continuo) -->
                            <!-- La lógica CSS arriba maneja el salto si copy_idx % 2 == 0 -->
                        </t>
                        <!-- Salto de página forzado al terminar las 3 copias de un bulto para separar del siguiente -->
                        <div style="page-break-after: always;"></div>
                    </t>
                </t>
            </t>
        </template>

        <!-- Template: Manifiesto de Carga (BL) -->
        <template id="template_report_shipping_bl">
            <!-- Usamos basic_layout para un control total de la página, sin headers/footers de Odoo -->
            <t t-call="web.basic_layout">
                <t t-foreach="docs" t-as="o">
                    <!-- Nivel 1: Iterar sobre cada línea/bulto -->
                    <t t-foreach="o.line_ids" t-as="line">
                        <!-- Nivel 2: Iterar 3 veces para las copias -->
                        <t t-foreach="[1, 2, 3]" t-as="copy_idx">
                            <!--
                                Bloque HBL Individual.
                                - height: 48vh -> Ocupa un poco menos de la mitad de la página.
                                - page-break-inside: avoid -> Evita que el bloque se parta entre páginas.
                                - border-bottom -> Línea punteada para recorte.
                            -->
                            <div class="hbl-block" style="height: 48vh; page-break-inside: avoid; border-bottom: 1px dashed #888; padding: 1rem; margin-bottom: 1vh; box-sizing: border-box;">
                                <div class="row">
                                    <div class="col-8">
                                        <h4>HOUSE BILL OF LADING</h4>
                                        <p class="mb-0"><strong>Agencia Origen:</strong> <span t-field="o.agencia_origen"/></p>
                                        <p class="mb-0"><strong>AWB/Contenedor:</strong> <span t-field="o.awb"/></p>
                                        <p><strong>Fecha Salida:</strong> <span t-field="o.date_shipping" t-options='{"widget": "date"}'/></p>
                                    </div>
                                    <div class="col-4 text-end">
                                        <img t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo)" style="max-height: 50px;" alt="Logo"/>
                                        <h5 class="mt-2">Copia <t t-esc="copy_idx"/>/3</h5>
                                    </div>
                                </div>

                                <div class="row mt-3">
                                    <div class="col-6">
                                        <strong>Remitente (Shipper):</strong>
                                        <div t-field="line.sender_id" t-options='{"widget": "contact", "fields": ["name", "address", "phone", "vat"], "no_marker": True}'/>
                                    </div>
                                    <div class="col-6">
                                        <strong>Destinatario (Consignee):</strong>
                                        <div t-field="line.receiver_id" t-options='{"widget": "contact", "fields": ["name", "address", "phone", "vat"], "no_marker": True}'/>
                                    </div>
                                </div>

                                <table class="table table-sm table-bordered mt-3">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Código Bulto</th>
                                            <th>Mercancía</th>
                                            <th class="text-end">Cant.</th>
                                            <th class="text-end">Peso (Kg)</th>
                                            <th class="text-end">Volumen (m³)</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td><span t-if="line.package_code != 'Borrador'" t-field="line.package_code"/></td>
                                            <td><span t-field="line.description"/></td>
                                            <td class="text-end"><span t-field="line.packages_qty"/></td>
                                            <td class="text-end"><span t-field="line.weight"/></td>
                                            <td class="text-end"><span t-field="line.volume" t-options='{"widget": "float", "precision": 3}'/></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </t>
                    </t>
                </t>
            </t>
        </template>
    </data>
</odoo>