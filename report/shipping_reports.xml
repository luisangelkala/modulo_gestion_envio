<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="action_report_shipping_labels" model="ir.actions.report">
            <field name="name">Etiquetas de Bulto (QR)</field>
            <field name="model">shipping.management</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">modulo_gestion_envio.report_shipping_labels</field>
            <field name="report_file">modulo_gestion_envio.report_shipping_labels</field>
            <field name="print_report_name">'Etiquetas - %s' % object.name</field>
        </record>

        <record id="action_report_shipping_bl" model="ir.actions.report">
            <field name="name">HBL (3 Copias)</field>
            <field name="model">shipping.management</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">modulo_gestion_envio.report_shipping_hbl</field>
            <field name="report_file">modulo_gestion_envio.report_shipping_hbl</field>
            <field name="print_report_name">'HBL - %s' % object.name</field>
        </record>

        <template id="report_shipping_labels">
            <t t-call="web.basic_layout">
                <div class="page">
                    <t t-foreach="docs" t-as="o">
                        <t t-foreach="o.line_ids" t-as="line">
                            <div style="page-break-after: always; border: 2px solid black; padding: 15px; text-align: center; margin: 10px;">
                                <h3>REF: <span t-field="o.name"/></h3>
                                <div style="margin: 20px 0;">
                                    <img t-att-src="'/report/barcode/?barcode_type=QR&amp;value=%s&amp;width=200&amp;height=200' % o.name" style="width:200px;height:200px"/>
                                </div>
                                <strong>Bulto ID:</strong> <span t-field="line.package_code"/><br/>
                                <strong>Cliente:</strong> <span t-field="line.receiver_id.name"/><br/>
                                <strong>Destino:</strong> <span t-field="line.receiver_id.city"/>, <span t-field="line.receiver_id.country_id.code"/>
                            </div>
                        </t>
                    </t>
                </div>
            </t>
        </template>

        <template id="report_shipping_hbl">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-foreach="o.line_ids" t-as="line">
                        <t t-foreach="[1, 2, 3]" t-as="copy_idx">
                            <div class="hbl-article" t-att-style="'position: relative; height: 48vh; margin-bottom: 1vh; box-sizing: border-box; page-break-inside: avoid; ' + ('page-break-after: always;' if copy_idx % 2 == 0 and copy_idx != 3 else '')">
                                
                                <table style="width: 100%; border-collapse: collapse; border: 1px solid black; font-size: 11px;">
                                    <tr>
                                        <td style="border: 1px solid black; width: 20%; text-align: center;">
                                            <img t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo)" style="max-height: 45px; max-width: 100%;" alt="Logo"/>
                                        </td>
                                        <td style="border: 1px solid black; width: 50%; text-align: center; font-weight: bold; font-size: 14px;">
                                            COMBINED TRANSPORT BILL OF LADING
                                        </td>
                                        <td style="border: 1px solid black; width: 30%; padding: 0;">
                                            <div style="border-bottom: 1px solid black; padding: 4px;">
                                                <strong>BOOKING NUMBER / B/L NUMBER</strong><br/>
                                                <span t-field="o.name"/>
                                                <div style="float: right; font-size: 8px;">COPY <t t-esc="copy_idx"/>/3</div>
                                            </div>
                                            <div style="padding: 4px; background-color: #f9f9f9;">
                                                <strong>EXPORT REFERENCES</strong><br/>
                                                <span style="font-size: 16px; font-weight: bold;" t-esc="line.package_code"/>
                                            </div>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="border: 1px solid black; padding: 4px; vertical-align: top;" colspan="1">
                                            <strong>1. SHIPPER / EXPORTER</strong><br/>
                                            <span t-field="line.sender_id.name" style="font-weight:bold;"/><br/>
                                            <span t-field="line.sender_id.street"/><t t-if="line.sender_id.street2">, <span t-field="line.sender_id.street2"/></t><br/>
                                            <span t-field="line.sender_id.city"/>, <span t-field="line.sender_id.country_id.name"/><br/>
                                            Tel: <span t-field="line.sender_id.phone"/><br/>
                                            ID/VAT: <span t-field="line.sender_id.vat"/>
                                        </td>
                                        <td style="border: 1px solid black; padding: 4px; vertical-align: top;" colspan="2">
                                            <strong>2. CONSIGNEE</strong><br/>
                                            <span t-field="line.receiver_id.name" style="font-weight:bold;"/><br/>
                                            <span t-field="line.receiver_id.street"/><t t-if="line.receiver_id.street2">, <span t-field="line.receiver_id.street2"/></t><br/>
                                            <span t-field="line.receiver_id.city"/>, <span t-field="line.receiver_id.country_id.name"/><br/>
                                            Tel: <span t-field="line.receiver_id.phone"/><br/>
                                            ID/VAT: <span t-field="line.receiver_id.vat"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="border: 1px solid black; padding: 4px; vertical-align: top;" colspan="1">
                                            <strong>NOTIFY PARTY / INTERMEDIATE CONSIGNEE</strong><br/>
                                            ORDAZ INVESTMENT GROUP, S.A.<br/>
                                            Manzana 14, Lote 10, Calle 4ta<br/>
                                            France Field, Zona Libre de Colón<br/>
                                            Rep. de Panamá
                                        </td>
                                        <td style="border: 1px solid black; padding: 4px; vertical-align: top;" colspan="2">
                                            <strong>FOR DELIVERY APPLY TO:</strong><br/>
                                            <span style="font-size: 18px; font-weight: bold; padding-left: 20px;">ENVIO</span>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="border: 1px solid black; padding: 4px; vertical-align: top;" colspan="1">
                                            <strong>PORT OF DISCHARGE:</strong> MARIEL, CU.
                                        </td>
                                        <td style="border: 1px solid black; padding: 4px; vertical-align: top;" colspan="2">
                                            <strong>PLACE OF DELIVERY:</strong> CUBANACAN
                                        </td>
                                    </tr>
                                </table>

                                <table style="width: 100%; border-collapse: collapse; border: 1px solid black; font-size: 10px; border-top: none;">
                                    <tr style="text-align: center; font-weight: bold; background-color: #f2f2f2;">
                                        <td style="border: 1px solid black; padding: 3px; width: 20%;">MARKS AND NUMBERS</td>
                                        <td style="border: 1px solid black; padding: 3px; width: 10%;">NUMBER OF PACKS</td>
                                        <td style="border: 1px solid black; padding: 3px; width: 45%;">DESCRIPTION OF COMMODITIES in schedule B detail</td>
                                        <td style="border: 1px solid black; padding: 3px; width: 15%;">GROSS WEIGHT (kg)</td>
                                        <td style="border: 1px solid black; padding: 3px; width: 10%;">VALOR (USD)</td>
                                    </tr>
                                    <tr style="text-align: center; vertical-align: top; height: 50px;">
                                        <td style="border: 1px solid black; padding: 3px;">
                                            <span t-esc="line.package_code"/>
                                        </td>
                                        <td style="border: 1px solid black; padding: 3px;">
                                            <span t-esc="line.packages_qty or '1'"/>
                                        </td>
                                        <td style="border: 1px solid black; padding: 3px; text-align: left;">
                                            <span t-esc="line.description"/>
                                        </td>
                                        <td style="border: 1px solid black; padding: 3px;">
                                            <span t-esc="line.weight"/><br/><br/>
                                            <strong>CUBICAJE (M3):</strong><br/>
                                            <span t-esc="line.volume" t-options='{"widget": "float", "precision": 3}'/>
                                        </td>
                                        <td style="border: 1px solid black; padding: 3px;">NVD</td>
                                    </tr>
                                </table>

                                <table style="width: 100%; border-collapse: collapse; border: 1px solid black; font-size: 10px; border-top: none;">
                                    <tr>
                                        <td style="border: 1px solid black; width: 33%; padding: 4px;"><strong>FREIGHT AND CHARGES</strong></td>
                                        <td style="border: 1px solid black; width: 33%; padding: 4px; text-align: center;"><strong>PREPAID</strong></td>
                                        <td style="border: 1px solid black; width: 34%; padding: 4px; text-align: center;"><strong>COLLECT</strong></td>
                                    </tr>
                                    <tr style="height: 12px;">
                                        <td style="border: 1px solid black;"></td>
                                        <td style="border: 1px solid black;"></td>
                                        <td style="border: 1px solid black;"></td>
                                    </tr>
                                    <tr>
                                        <td colspan="3" style="border: 1px solid black; padding: 5px;">
                                            <div style="display: flex; justify-content: space-between; align-items: flex-end; height: 50px;">
                                                <div style="width: 70%;">
                                                    <strong style="text-decoration: underline;">Sólo para uso de la Aduana</strong><br/>
                                                    <strong>CUBANACAN</strong><br/>
                                                    BUQUE: <span t-esc="o.carrier"/><br/>
                                                    FIRMA: _________________________________<br/>
                                                    MANIFIESTO: <span t-esc="o.name"/>
                                                </div>
                                                <div style="width: 30%; text-align: right; vertical-align: bottom;">
                                                    <span style="font-size: 12px; font-weight: bold;" t-esc="datetime.datetime.now().strftime('%d/%m/%Y')"/>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </t>
                        <div style="page-break-after: always;"></div>
                    </t>
                </t>
            </t>
        </template>
    </data>
</odoo>