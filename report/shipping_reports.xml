<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="paperformat_shipping_label" model="report.paperformat">
            <field name="name">Etiqueta 100x75mm</field>
            <field name="default" eval="True"/>
            <field name="format">custom</field>
            <field name="page_height">75</field>
            <field name="page_width">100</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">2</field>
            <field name="margin_bottom">2</field>
            <field name="margin_left">2</field>
            <field name="margin_right">2</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">0</field>
            <field name="dpi">90</field>
        </record>

        <record id="action_report_shipping_labels" model="ir.actions.report">
            <field name="name">Etiquetas de Bulto (QR)</field>
            <field name="model">shipping.management</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">modulo_gestion_envio.report_shipping_labels</field>
            <field name="report_file">modulo_gestion_envio.report_shipping_labels</field>
            <field name="print_report_name">'Etiquetas - %s' % object.name</field>
            <field name="binding_model_id" eval="False"/>
            <field name="paperformat_id" ref="modulo_gestion_envio.paperformat_hbl_strict"/>
        </record>

        <record id="paperformat_hbl_strict" model="report.paperformat">
            <field name="name">HBL Strict A4</field>
            <field name="default" eval="True"/>
            <field name="format">A4</field>
            <field name="page_height">0</field>
            <field name="page_width">0</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">5</field>
            <field name="margin_bottom">5</field>
            <field name="margin_left">5</field>
            <field name="margin_right">5</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">0</field>
            <field name="dpi">90</field>
        </record>

        <record id="action_report_shipping_bl" model="ir.actions.report">
            <field name="name">HBL (3 Copias)</field>
            <field name="model">shipping.management</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">modulo_gestion_envio.report_shipping_hbl</field>
            <field name="report_file">modulo_gestion_envio.report_shipping_hbl</field>
            <field name="print_report_name">'HBL - %s' % object.name</field>
            <field name="paperformat_id" ref="paperformat_hbl_strict"/>
        </record>

        <template id="report_shipping_labels">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <div class="page">
                        <meta charset="utf-8"/>
                        <t t-set="lines_to_print" t-value="o.line_ids.filtered(lambda l: l.print_selected) or o.line_ids"/>
                        <t t-foreach="lines_to_print" t-as="line">
                            <div style="height: 32vh; width: 100%; box-sizing: border-box; padding: 10px; border-bottom: 1px dashed #999; page-break-inside: avoid; overflow: hidden;">
                                <div style="width: 18cm; margin: 0 auto; border: 1px solid black; padding: 15px; box-sizing: border-box;">
                                    <div style="text-align: center; margin-bottom: 5px;">
                                        <h5 style="margin: 0; font-weight: bold;">CUBANACAN EXPRESS</h5>
                                        <h6 style="margin: 0;">ORDAZ INVESTMENT GROUP, S.A.</h6>
                                    </div>

                                    <table style="width: 100%; border-collapse: collapse;">
                                        <tr>
                                            <td style="width: 75%; vertical-align: top; padding-right: 10px; line-height: 1.6;">
                                                <strong>REMITENTE:</strong> <span t-esc="line.sender_id.name"/><br/>
                                                <strong>CONSIGNATARIO:</strong> <span t-esc="line.receiver_id.name"/><br/>
                                                <strong>ID:</strong> <span t-esc="line.receiver_id.vat"/><br/>
                                                <strong>DIRECCION:</strong> <span t-esc="line.receiver_id.street"/>, <span t-if="line.receiver_id.street2" t-esc="line.receiver_id.street2"/> <span t-if="line.receiver_id.street2">, </span> <span t-esc="line.receiver_id.city"/>, <span t-esc="line.receiver_id.state_id.name"/><br/>
                                                <strong>TELEFONO:</strong> <span t-esc="line.receiver_id.phone"/><br/>
                                                <strong>DESCRIPCION:</strong> <span t-esc="line.description"/><br/>
                                                <strong>CLASIFICACION:</strong> ENVIO
                                            </td>
                                            <td style="width: 25%; vertical-align: top; text-align: center;">
                                                <img t-if="line.qr_image" t-att-src="image_data_uri(line.qr_image)" style="width: 120px; height: 120px; margin-bottom: 5px;" alt="QR Code"/>
                                                <br/>
                                                <strong>PESO:</strong> <span t-esc="line.weight"/> Kg<br/>
                                                <strong>PIEZAS:</strong> 1<br/>
                                                <strong>GUIA:</strong> <span t-esc="o.name"/>
                                            </td>
                                        </tr>
                                    </table>

                                    <div style="text-align: center; margin-top: 5px;">
                                        <span t-field="line.package_code" t-options="{'widget': 'barcode', 'symbology': 'Code128', 'width': 250, 'height': 45, 'img_style': 'width: 250px; height: 45px; margin: 0 auto; image-rendering: crisp-edges; image-rendering: pixelated;'}"/><br/>
                                        <span t-esc="line.package_code"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>
                </t>
            </t>
        </template>

        <template id="report_shipping_hbl">
            <t t-call="web.html_container">
                <div class="page">
                    <t t-foreach="docs" t-as="o">
                        <!-- Lógica de impresión selectiva: Si hay marcados, imprime solo esos. Si no, imprime todos. -->
                        <t t-set="lines_to_print" t-value="o.line_ids.filtered(lambda x: x.print_selected) or o.line_ids"/>
                        <t t-foreach="lines_to_print" t-as="line">
                            <t t-foreach="[1, 2, 3]" t-as="copy_idx">
                                <div class="hbl-article" style="position: relative; height: 48vh; margin-bottom: 1.5vh; box-sizing: border-box; page-break-inside: avoid;">
                                    
                                    <table style="width: 100%; border-collapse: collapse; border: 1px solid black; font-size: 11px;">
                                        <tr>
                                            <td style="border: 1px solid black; width: 20%; text-align: center;">
                                                <img t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo)" style="max-height: 45px; max-width: 100%;" alt="Logo"/>
                                            </td>
                                            <td style="border: 1px solid black; width: 50%; text-align: center; font-weight: bold; font-size: 14px;">
                                                COMBINED TRANSPORT BILL OF LADING
                                            </td>
                                            <td style="border: 1px solid black; width: 30%; padding: 0;">
                                                <div style="border-bottom: 1px solid black; padding: 4px;">
                                                    <strong>BOOKING NUMBER / B/L NUMBER</strong><br/>
                                                    <span t-field="o.name"/>
                                                    <div style="float: right; font-size: 8px;">COPY <t t-esc="copy_idx"/>/3</div>
                                                </div>
                                                <div style="padding: 4px; background-color: #f9f9f9;">
                                                    <strong>EXPORT REFERENCES</strong><br/>
                                                    <span style="font-size: 16px; font-weight: bold;" t-esc="line.package_code"/>
                                                </div>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="border: 1px solid black; padding: 4px; vertical-align: top;" colspan="1">
                                                <strong>1. SHIPPER / EXPORTER</strong><br/>
                                                <span t-esc="line.sender_id.name" style="font-weight:bold;"/><br/>
                                                <t t-if="line.sender_id.street"><span t-esc="line.sender_id.street"/></t>
                                                <t t-if="line.sender_id.street2">, <span t-esc="line.sender_id.street2"/></t><br/>
                                                <t t-if="line.sender_id.city"><span t-esc="line.sender_id.city"/>, </t>
                                                <span t-esc="line.sender_id.country_id.name"/><br/>
                                                Tel: <span t-esc="line.sender_id.phone"/><br/>
                                                ID/VAT: <span t-esc="line.sender_id.vat"/>
                                            </td>
                                            <td style="border: 1px solid black; padding: 4px; vertical-align: top;" colspan="2">
                                                <strong>2. CONSIGNEE</strong><br/>
                                                <span t-esc="line.receiver_id.name" style="font-weight:bold;"/><br/>
                                                <t t-if="line.receiver_id.street"><span t-esc="line.receiver_id.street"/></t>
                                                <t t-if="line.receiver_id.street2">, <span t-esc="line.receiver_id.street2"/></t><br/>
                                                <t t-if="line.receiver_id.city"><span t-esc="line.receiver_id.city"/>, </t>
                                                <span t-esc="line.receiver_id.country_id.name"/><br/>
                                                Tel: <span t-esc="line.receiver_id.phone"/><br/>
                                                ID/VAT: <span t-esc="line.receiver_id.vat"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="border: 1px solid black; padding: 4px; vertical-align: top;" colspan="1">
                                                <strong>NOTIFY PARTY / INTERMEDIATE CONSIGNEE</strong><br/>
                                                ORDAZ INVESTMENT GROUP, S.A.<br/>
                                                Manzana 14, Lote 10, Calle 4ta<br/>
                                                France Field, Zona Libre de Colon<br/>
                                                Rep. de Panama
                                            </td>
                                            <td style="border: 1px solid black; padding: 4px; vertical-align: top;" colspan="2">
                                                <strong>FOR DELIVERY APPLY TO:</strong><br/>
                                                <span style="font-size: 18px; font-weight: bold; padding-left: 20px;">ENVIO</span>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="border: 1px solid black; padding: 4px; vertical-align: top;" colspan="1">
                                                <strong>PORT OF DISCHARGE:</strong> MARIEL, CU.
                                            </td>
                                            <td style="border: 1px solid black; padding: 4px; vertical-align: top;" colspan="2">
                                                <strong>PLACE OF DELIVERY:</strong> CUBANACAN
                                            </td>
                                        </tr>
                                    </table>

                                    <table style="width: 100%; border-collapse: collapse; border: 1px solid black; font-size: 10px; border-top: none;">
                                        <tr style="text-align: center; font-weight: bold; background-color: #f2f2f2;">
                                            <td style="border: 1px solid black; padding: 3px; width: 20%;">MARKS AND NUMBERS</td>
                                            <td style="border: 1px solid black; padding: 3px; width: 10%;">NUMBER OF PACKS</td>
                                            <td style="border: 1px solid black; padding: 3px; width: 45%;">DESCRIPTION OF COMMODITIES in schedule B detail</td>
                                            <td style="border: 1px solid black; padding: 3px; width: 15%;">GROSS WEIGHT (kg)</td>
                                            <td style="border: 1px solid black; padding: 3px; width: 10%;">VALOR (USD)</td>
                                        </tr>
                                        <tr style="text-align: center; vertical-align: top; height: 50px;">
                                            <td style="border: 1px solid black; padding: 3px;">
                                                <span t-esc="line.package_code"/>
                                            </td>
                                            <td style="border: 1px solid black; padding: 3px;">
                                                <span t-esc="line.packages_qty or '1'"/>
                                            </td>
                                            <td style="border: 1px solid black; padding: 3px; text-align: left;">
                                                <span t-esc="line.description"/>
                                            </td>
                                            <td style="border: 1px solid black; padding: 3px;">
                                                <span t-esc="line.weight"/><br/><br/>
                                                <strong>CUBICAJE (M3):</strong><br/>
                                                <span t-esc="line.volume" t-options='{"widget": "float", "precision": 3}'/>
                                            </td>
                                            <td style="border: 1px solid black; padding: 3px;">NVD</td>
                                        </tr>
                                    </table>

                                    <table style="width: 100%; border-collapse: collapse; border: 1px solid black; font-size: 10px; border-top: none;">
                                        <tr>
                                            <td style="border: 1px solid black; width: 33%; padding: 4px;"><strong>FREIGHT AND CHARGES</strong></td>
                                            <td style="border: 1px solid black; width: 33%; padding: 4px; text-align: center;"><strong>PREPAID</strong></td>
                                            <td style="border: 1px solid black; width: 34%; padding: 4px; text-align: center;"><strong>COLLECT</strong></td>
                                        </tr>
                                        <tr style="height: 12px;">
                                            <td style="border: 1px solid black;"></td>
                                            <td style="border: 1px solid black;"></td>
                                            <td style="border: 1px solid black;"></td>
                                        </tr>
                                        <tr>
                                            <td colspan="3" style="border: 1px solid black; padding: 5px;">
                                                <table style="width: 100%; height: 50px; border: none;">
                                                    <tr>
                                                        <td style="width: 70%; vertical-align: top; border: none;">
                                                            <strong style="text-decoration: underline;">Solo para uso de la Aduana</strong><br/>
                                                            <strong>CUBANACAN</strong><br/>
                                                            BUQUE: <span t-esc="o.carrier.name"/><br/>
                                                            FIRMA: _________________________________<br/>
                                                            MANIFIESTO: <span t-esc="o.name"/>
                                                        </td>
                                                        <td style="width: 30%; text-align: right; vertical-align: bottom; border: none;">
                                                            <span style="font-size: 12px; font-weight: bold;" t-esc="datetime.datetime.now().strftime('%d/%m/%Y')"/>
                                                        </td>
                                                    </tr>
                                                </table>
                                            </td>
                                        </tr>
                                    </table>
                                </div>
                            </t>
                        </t>
                    </t>
                </div>
            </t>
        </template>
    </data>
</odoo>